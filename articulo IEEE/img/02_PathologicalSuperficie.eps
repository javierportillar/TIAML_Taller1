%AXGEndBitmap
GR
GR
GS
[0.48 0 0 0.48018 0 0] CT
[1 0 0 1 0 0] CT
N
0 0 M
875 0 L
875 656 L
0 656 L
0 0 L
cp
clip
GS
0 0 translate
700 131 scale
%AXGBeginBitmap: java.awt.image.BufferedImage
{{
/RawData currentfile /ASCII85Decode filter def
/Data RawData /FlateDecode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Decode [0 1 0 1 0 1]
  /DataSource Data
  /Height 131
  /ImageMatrix [700 0 0 131 0 0]
  /Width 700
  /BitsPerComponent 8
>> image
} stopped {handleerror} if
  RawData flushfile
} exec
