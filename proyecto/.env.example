# =====================================================================
# Seleccion del modelo (init_chat_model de LangChain - Taller 3)
# Opciones validas para LLM_PROVIDER:
#   - google_genai (recomendado, soporta gemini-2.5-flash gratis)
#   - openai
#   - ollama (local, requiere ollama serve)
# =====================================================================

LLM_PROVIDER=ollama
MODEL_NAME=gemma3:latest
TEMPERATURE=0.0
MAX_CONTEXT_CHARS=200000

# --- Ollama local ---
OLLAMA_BASE_URL=http://127.0.0.1:11434

# --- Memoria persistente LangGraph/Postgres (Fase 4) ---
LANGGRAPH_DB_URL=postgresql://qbano:qbano_dev@localhost:5432/qbano_agent

# --- Google Gemini (gratis en https://aistudio.google.com/apikey) ---
# LLM_PROVIDER=google_genai
# MODEL_NAME=gemini-2.5-flash
# GEMINI_API_KEY=tu_clave_de_gemini
# TEMPERATURE=0.1
# MAX_CONTEXT_CHARS=200000

